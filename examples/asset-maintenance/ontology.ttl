@prefix ex: <http://example.org/asset-maintenance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:AssetMaintenanceOntology
    a owl:Ontology ;
    rdfs:label "Asset maintenance ontology" ;
    rdfs:comment "A compact ontology for testing business-rule to SHACL generation." .

ex:Asset
    a owl:Class ;
    rdfs:label "Asset" ;
    rdfs:comment "A physical or logical asset managed by the maintenance organization." .

ex:CriticalAsset
    a owl:Class ;
    rdfs:subClassOf ex:Asset ;
    rdfs:label "Critical asset" ;
    rdfs:comment "An asset whose failure may create operational, safety, or compliance risk." .

ex:Machine
    a owl:Class ;
    rdfs:subClassOf ex:Asset ;
    rdfs:label "Machine" ;
    rdfs:comment "A maintainable asset that can be monitored by sensors." .

ex:Sensor
    a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "A device that produces measurements about an asset." .

ex:Measurement
    a owl:Class ;
    rdfs:label "Measurement" ;
    rdfs:comment "A numeric observation produced by a sensor." .

ex:Site
    a owl:Class ;
    rdfs:label "Site" ;
    rdfs:comment "A physical site where assets are installed." .

ex:Department
    a owl:Class ;
    rdfs:label "Department" ;
    rdfs:comment "An organizational unit responsible for maintenance work." .

ex:WorkOrder
    a owl:Class ;
    rdfs:label "Work order" ;
    rdfs:comment "A container for one or more maintenance tasks." .

ex:MaintenanceTask
    a owl:Class ;
    rdfs:label "Maintenance task" ;
    rdfs:comment "A planned or corrective task performed on an asset." .

ex:Inspection
    a owl:Class ;
    rdfs:label "Inspection" ;
    rdfs:comment "A formal check performed on an asset at a given date." .

ex:Operator
    a owl:Class ;
    rdfs:label "Operator" ;
    rdfs:comment "A person assigned to perform maintenance or inspections." .

ex:Certification
    a owl:Class ;
    rdfs:label "Certification" ;
    rdfs:comment "A qualification required to work on critical assets." .

ex:LifecycleStatus
    a owl:Class ;
    rdfs:label "Lifecycle status" ;
    rdfs:comment "A controlled status describing the lifecycle state of an asset." .

ex:PriorityLevel
    a owl:Class ;
    rdfs:label "Priority level" ;
    rdfs:comment "A controlled priority value for maintenance tasks." .

ex:RiskLevel
    a owl:Class ;
    rdfs:label "Risk level" ;
    rdfs:comment "A controlled risk classification for critical assets." .

ex:assetIdentifier
    a owl:DatatypeProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range xsd:string ;
    rdfs:label "asset identifier" ;
    rdfs:comment "A stable identifier assigned to an asset." .

ex:serialNumber
    a owl:DatatypeProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range xsd:string ;
    rdfs:label "serial number" ;
    rdfs:comment "A manufacturer's serial number for an asset." .

ex:manufacturer
    a owl:DatatypeProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range xsd:string ;
    rdfs:label "manufacturer" ;
    rdfs:comment "The name of the organization that manufactured the asset." .

ex:installationDate
    a owl:DatatypeProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range xsd:date ;
    rdfs:label "installation date" ;
    rdfs:comment "The date on which an asset was installed." .

ex:unitCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:Measurement ;
    rdfs:range xsd:string ;
    rdfs:label "unit code" ;
    rdfs:comment "The measurement unit code, such as CEL, RPM, or BAR." .

ex:measurementValue
    a owl:DatatypeProperty ;
    rdfs:domain ex:Measurement ;
    rdfs:range xsd:decimal ;
    rdfs:label "measurement value" ;
    rdfs:comment "The numeric value recorded by a sensor." .

ex:dueDate
    a owl:DatatypeProperty ;
    rdfs:domain ex:MaintenanceTask ;
    rdfs:range xsd:date ;
    rdfs:label "due date" ;
    rdfs:comment "The date by which a maintenance task must be completed." .

ex:inspectionDate
    a owl:DatatypeProperty ;
    rdfs:domain ex:Inspection ;
    rdfs:range xsd:date ;
    rdfs:label "inspection date" ;
    rdfs:comment "The date on which an inspection was performed." .

ex:locatedIn
    a owl:ObjectProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range ex:Site ;
    rdfs:label "located in" ;
    rdfs:comment "Links an asset to the site where it is located." .

ex:hasLifecycleStatus
    a owl:ObjectProperty ;
    rdfs:domain ex:Asset ;
    rdfs:range ex:LifecycleStatus ;
    rdfs:label "has lifecycle status" ;
    rdfs:comment "Links an asset to one controlled lifecycle status." .

ex:hasSensor
    a owl:ObjectProperty ;
    rdfs:domain ex:Machine ;
    rdfs:range ex:Sensor ;
    rdfs:label "has sensor" ;
    rdfs:comment "Links a machine to a sensor that monitors it." .

ex:producesMeasurement
    a owl:ObjectProperty ;
    rdfs:domain ex:Sensor ;
    rdfs:range ex:Measurement ;
    rdfs:label "produces measurement" ;
    rdfs:comment "Links a sensor to the measurements it produces." .

ex:hasAsset
    a owl:ObjectProperty ;
    rdfs:domain ex:MaintenanceTask ;
    rdfs:range ex:Asset ;
    rdfs:label "has asset" ;
    rdfs:comment "Links a maintenance task to the asset it concerns." .

ex:hasPriority
    a owl:ObjectProperty ;
    rdfs:domain ex:MaintenanceTask ;
    rdfs:range ex:PriorityLevel ;
    rdfs:label "has priority" ;
    rdfs:comment "Links a maintenance task to one controlled priority level." .

ex:assignedTo
    a owl:ObjectProperty ;
    rdfs:domain ex:MaintenanceTask ;
    rdfs:range ex:Operator ;
    rdfs:label "assigned to" ;
    rdfs:comment "Links a maintenance task to the operator assigned to it." .

ex:inspectsAsset
    a owl:ObjectProperty ;
    rdfs:domain ex:Inspection ;
    rdfs:range ex:Asset ;
    rdfs:label "inspects asset" ;
    rdfs:comment "Links an inspection to the asset that was inspected." .

ex:hasTask
    a owl:ObjectProperty ;
    rdfs:domain ex:WorkOrder ;
    rdfs:range ex:MaintenanceTask ;
    rdfs:label "has task" ;
    rdfs:comment "Links a work order to one of its maintenance tasks." .

ex:responsibleDepartment
    a owl:ObjectProperty ;
    rdfs:domain ex:WorkOrder ;
    rdfs:range ex:Department ;
    rdfs:label "responsible department" ;
    rdfs:comment "Links a work order to the department responsible for it." .

ex:hasRiskLevel
    a owl:ObjectProperty ;
    rdfs:domain ex:CriticalAsset ;
    rdfs:range ex:RiskLevel ;
    rdfs:label "has risk level" ;
    rdfs:comment "Links a critical asset to one controlled risk level." .

ex:requiresCertification
    a owl:ObjectProperty ;
    rdfs:domain ex:CriticalAsset ;
    rdfs:range ex:Certification ;
    rdfs:label "requires certification" ;
    rdfs:comment "Links a critical asset to a certification required for maintenance work." .

ex:Active
    a ex:LifecycleStatus ;
    rdfs:label "Active" .

ex:Inactive
    a ex:LifecycleStatus ;
    rdfs:label "Inactive" .

ex:Retired
    a ex:LifecycleStatus ;
    rdfs:label "Retired" .

ex:LowPriority
    a ex:PriorityLevel ;
    rdfs:label "Low priority" .

ex:MediumPriority
    a ex:PriorityLevel ;
    rdfs:label "Medium priority" .

ex:HighPriority
    a ex:PriorityLevel ;
    rdfs:label "High priority" .

ex:LowRisk
    a ex:RiskLevel ;
    rdfs:label "Low risk" .

ex:MediumRisk
    a ex:RiskLevel ;
    rdfs:label "Medium risk" .

ex:HighRisk
    a ex:RiskLevel ;
    rdfs:label "High risk" .
