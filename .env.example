# -----------------------------------------------------------------------------
# Remote inference
# -----------------------------------------------------------------------------

# Databricks OpenAI-compatible AI Gateway base URL.
# This value must be configured before remote inference can run.
DATABRICKS_BASE_URL=

# Databricks bearer token. Keep secrets out of version control.
DATABRICKS_TOKEN=


# -----------------------------------------------------------------------------
# SHARD public deployment
# -----------------------------------------------------------------------------

# Public disables local Hugging Face execution.
SHARD_DEPLOYMENT_PROFILE=public

# Unified serves the frontend, REST API and SSE from the same process.
SHARD_SERVICE_LAYOUT=unified

# Keep SHARD accessible only through the local reverse proxy.
SHARD_HOST=127.0.0.1

# Default SHARD listener port.
SHARD_PORT=8768


# -----------------------------------------------------------------------------
# Reverse proxy and CORS
# -----------------------------------------------------------------------------

# Comma-separated origins allowed to call the API from a browser.
SHARD_CORS_ALLOWED_ORIGINS=https://apps.citius.gal

# Immediate reverse proxies whose X-Forwarded-For header may be trusted.
SHARD_TRUSTED_PROXY_IPS=127.0.0.1


# -----------------------------------------------------------------------------
# Astrea
# -----------------------------------------------------------------------------

# Public Astrea endpoint used to generate ontology-derived baseline shapes.
SHARD_ASTREA_API_URL=https://astrea.linkeddata.es/api/shacl/document

# Maximum Astrea request duration in seconds.
ASTREA_TIMEOUT_SECONDS=1800


# -----------------------------------------------------------------------------
# Rate limits
# -----------------------------------------------------------------------------

# General requests allowed per client and minute.
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Requests allowed per client during a one-second burst.
RATE_LIMIT_BURST=200

# Expensive inference operations allowed per client and minute.
RATE_LIMIT_EXPENSIVE_REQUESTS_PER_MINUTE=120

# Asynchronous jobs that one client may create per minute.
RATE_LIMIT_JOB_CREATIONS_PER_MINUTE=60


# -----------------------------------------------------------------------------
# Concurrency
# -----------------------------------------------------------------------------

# Maximum number of running asynchronous jobs.
MAX_CONCURRENT_JOBS=50

# Maximum number of simultaneous Batch-to-Shapes workflows.
MAX_CONCURRENT_BATCH_WORKFLOWS=20

# Maximum number of simultaneous local model downloads.
# Local model execution is disabled in the public profile.
MAX_CONCURRENT_MODEL_DOWNLOADS=5

# Maximum number of queued asynchronous jobs.
MAX_QUEUED_JOBS=500


# -----------------------------------------------------------------------------
# Upload and document limits (MiB)
# -----------------------------------------------------------------------------

# Maximum size of the complete HTTP request body.
MAX_REQUEST_BODY_MB=256

# Maximum ontology size.
MAX_ONTOLOGY_UPLOAD_MB=200

# Maximum structured data-constraint batch size.
MAX_BATCH_UPLOAD_MB=50

# Maximum size of each domain validation profile.
MAX_VALIDATION_PROFILE_MB=20

# Maximum size of each SHACL document.
MAX_SHAPE_DOCUMENT_MB=50


# -----------------------------------------------------------------------------
# Timeouts (seconds)
# -----------------------------------------------------------------------------

# Timeout while establishing connections to inference providers.
HTTP_CONNECT_TIMEOUT_SECONDS=60

# General provider HTTP read/write timeout.
HTTP_READ_TIMEOUT_SECONDS=1800

# Maximum duration of one model request.
MODEL_TIMEOUT_SECONDS=1800

# Maximum wait for ontology embedding preparation.
EMBEDDING_TIMEOUT_SECONDS=3600

# Maximum duration of a complete Batch-to-Shapes workflow.
BATCH_WORKFLOW_TIMEOUT_SECONDS=7200

# Maximum SSE period without generation progress.
SSE_IDLE_TIMEOUT_SECONDS=1800

# Maximum runtime of an asynchronous job.
JOB_MAX_RUNTIME_SECONDS=7200