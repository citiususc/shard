@prefix prof: <http://example.org/asset-maintenance/profile#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

prof:GeneratedNodeShapeStructure
    a sh:NodeShape ;
    rdfs:label "Generated NodeShape structure" ;
    rdfs:comment "Checks that each generated SHACL NodeShape is targetable and contains at least one property constraint." ;
    sh:targetClass sh:NodeShape ;
    sh:property [
        sh:path sh:targetClass ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Each generated NodeShape must declare exactly one sh:targetClass IRI." ;
    ] ;
    sh:property [
        sh:path sh:property ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:message "Each generated NodeShape must contain at least one sh:property constraint." ;
    ] .

prof:GeneratedPropertyShapeStructure
    a sh:NodeShape ;
    rdfs:label "Generated property shape structure" ;
    rdfs:comment "Checks that each property shape has a path, at least one real constraint, and a human-readable validation message." ;
    sh:targetObjectsOf sh:property ;
    sh:property [
        sh:path sh:path ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Each generated property shape must declare exactly one sh:path IRI." ;
    ] ;
    sh:property [
        sh:path [
            sh:alternativePath (
                sh:minCount
                sh:maxCount
                sh:class
                sh:datatype
                sh:nodeKind
                sh:in
                sh:pattern
                sh:minInclusive
                sh:maxInclusive
                sh:hasValue
            )
        ] ;
        sh:minCount 1 ;
        sh:message "Each generated property shape must include at least one concrete constraint, such as sh:minCount, sh:maxCount, sh:class, sh:datatype, sh:pattern or sh:in." ;
    ] ;
    sh:property [
        sh:path sh:message ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Each generated property shape must include a human-readable sh:message." ;
    ] .
