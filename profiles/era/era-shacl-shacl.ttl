@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix era:  <http://data.europa.eu/949/> .
@prefix era-sh: <http://data.europa.eu/949/shapes/> .
@prefix eshsh: <http://data.europa.eu/949/shapes/meta/> .

#################################################################
# ERA-RINF SHACL for SHACL profile
#
# Validates the structure and metadata conventions of SHACL shapes
# generated by SHARD for the ERA/RINF use case.
#
# COMPLEMENTARY to the generic W3C shacl-shacl.ttl: it only encodes
# constraints SPECIFIC to the ERA gold standard (era-shapes.ttl) and
# NOT already covered by the generic meta-shapes. Generated shapes are
# validated against BOTH files, so nothing here duplicates the native
# SHACL structural checks (sh:path cardinality, sh:datatype / nodeKind,
# target well-formedness, logical operators, SPARQL body typing, ...).
#
# ERA conventions captured here:
#   1. ERA metadata on PropertyShapes / SPARQLConstraints
#      (era:affectedProperty, era:affectedClass, era:scope).
#   2. Controlled vocabulary of era:scope ("local" | "global").
#   3. Form of era:rinfIndex / era:eratvIndex provenance pointers.
#   4. sh:severity vocabulary (Violation | Warning) and English
#      message language tag expected by the ERA pipeline.
#   5. SPARQLConstraint completeness (executable SELECT, prefixes).
#
# CALIBRATION NOTE - every shape below has been checked against the
# gold standard so that a correct ERA reference shape does NOT raise a
# Violation. Consequences of that calibration:
#   - era:affectedProperty / era:affectedClass on SPARQLConstraints
#     may be MULTI-valued (dependency rules span several parameters),
#     so no sh:maxCount is imposed there.
#   - Metadata that the gold occasionally omits on SPARQL/edge cases
#     (affected*, sh:message) is required at sh:Warning severity, not
#     Violation, so generated shapes are still nudged toward it without
#     rejecting the reference set.
#   - era:scope is matched with a trimming-tolerant sh:pattern because
#     the gold standard contains a trailing-space variant ("local ").
#   - era:affectedProperty / era:affectedClass are NOT restricted to
#     the era: namespace (the gold also uses rdfs:, geosparql:, time:);
#     only sh:nodeKind sh:IRI is enforced.
#   - era:rinfIndex / era:eratvIndex are validated leniently (string
#     literal containing a digit): the gold has trailing spaces,
#     leading dots, comma lists and letter suffixes ("4.1.3.b").
#################################################################


### 1. Objects of the ERA "affected*" metadata must be IRIs ################

eshsh:AffectedPropertyValue
    a sh:NodeShape ;
    rdfs:comment "The object of era:affectedProperty must be an IRI (any namespace)." ;
    sh:targetObjectsOf era:affectedProperty ;
    sh:nodeKind sh:IRI ;
    sh:message "era:affectedProperty must reference an IRI (e.g. era:maximumPermittedSpeed)." .

eshsh:AffectedClassValue
    a sh:NodeShape ;
    rdfs:comment "The object of era:affectedClass must be an IRI (any namespace)." ;
    sh:targetObjectsOf era:affectedClass ;
    sh:nodeKind sh:IRI ;
    sh:message "era:affectedClass must reference an IRI (e.g. era:RunningTrack)." .


### 2. PropertyShape ERA-metadata conventions ##############################

eshsh:EraPropertyShape
    a sh:NodeShape ;
    rdfs:comment "ERA metadata conventions for every sh:PropertyShape." ;
    sh:targetClass sh:PropertyShape ;

    # One affected property is the norm, but a sequence path
    # (sh:path (p1 p2 ...)) legitimately declares several. Presence is
    # nudged (Warning); multiplicity is therefore not a hard error.
    sh:property [
        sh:path era:affectedProperty ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "PropertyShape should declare an era:affectedProperty." ;
    ] ;

    sh:property [
        sh:path era:affectedClass ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "PropertyShape should declare at least one era:affectedClass." ;
    ] ;

    sh:property [
        sh:path era:scope ;
        sh:maxCount 1 ;
        sh:message "era:scope must be single-valued." ;
    ] ;

    sh:property [
        sh:path sh:message ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "PropertyShape should provide an sh:message." ;
    ] .


### 3. SPARQLConstraint ERA-metadata + executability conventions ###########

eshsh:EraSparqlConstraint
    a sh:NodeShape ;
    rdfs:comment "ERA metadata + executability conventions for sh:SPARQLConstraint." ;
    sh:targetClass sh:SPARQLConstraint ;

    # affectedProperty / affectedClass may be MULTI-valued: SPARQL
    # dependency rules relate several parameters. Presence nudged
    # (Warning); no maxCount imposed.
    sh:property [
        sh:path era:affectedProperty ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "SPARQLConstraint should declare at least one era:affectedProperty." ;
    ] ;
    sh:property [
        sh:path era:affectedClass ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "SPARQLConstraint should declare at least one era:affectedClass." ;
    ] ;

    sh:property [
        sh:path era:scope ;
        sh:maxCount 1 ;
        sh:message "era:scope must be single-valued." ;
    ] ;

    # Executable SELECT body is mandatory (hard: the gold always has it).
    sh:property [
        sh:path sh:select ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Each SPARQLConstraint must provide exactly one sh:select query." ;
    ] ;

    # Prefixes recommended; soft because a few gold constraints inline
    # PREFIX declarations inside the query text.
    sh:property [
        sh:path sh:prefixes ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "SPARQLConstraint should declare sh:prefixes for the SELECT body." ;
    ] ;

    sh:property [
        sh:path sh:message ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "SPARQLConstraint should provide an sh:message." ;
    ] .


### 4. era:scope controlled vocabulary #####################################
#     Trimming-tolerant pattern: accepts "local"/"global" with optional
#     surrounding whitespace (the gold contains a "local " variant).

eshsh:ScopeValue
    a sh:NodeShape ;
    rdfs:comment "era:scope is a controlled string literal: local | global." ;
    sh:targetObjectsOf era:scope ;
    sh:datatype xsd:string ;
    sh:pattern "^\\s*(local|global)\\s*$" ;
    sh:message "era:scope value must be \"local\" or \"global\"." .


### 5. ERA index provenance annotations ####################################
#     Lenient: string literal containing at least one digit.

eshsh:RinfIndexValue
    a sh:NodeShape ;
    rdfs:comment "era:rinfIndex is a string pointer into the RINF Application Guide." ;
    sh:targetObjectsOf era:rinfIndex ;
    sh:datatype xsd:string ;
    sh:pattern "[0-9]" ;
    sh:message "era:rinfIndex must be a string carrying the RINF index (e.g. \"1.1.1.2.2.1.1\")." .

eshsh:EratvIndexValue
    a sh:NodeShape ;
    rdfs:comment "era:eratvIndex is a string pointer into ERATV." ;
    sh:targetObjectsOf era:eratvIndex ;
    sh:datatype xsd:string ;
    sh:pattern "[0-9]" ;
    sh:message "era:eratvIndex must be a string carrying the ERATV index (e.g. \"4.5.3.4\")." .


### 6. sh:severity vocabulary (ERA uses only Violation / Warning) ###########

eshsh:SeverityValue
    a sh:NodeShape ;
    rdfs:comment "ERA shapes use only sh:Violation or sh:Warning as severity." ;
    sh:targetObjectsOf sh:severity ;
    sh:in ( sh:Violation sh:Warning ) ;
    sh:message "sh:severity must be sh:Violation or sh:Warning in ERA shapes." .


### 7. sh:message language-tag convention (soft) ###########################

eshsh:MessageLanguageTag
    a sh:NodeShape ;
    rdfs:comment "ERA validation messages should carry an @en language tag." ;
    sh:targetObjectsOf sh:message ;
    sh:severity sh:Warning ;
    sh:languageIn ( "en" ) ;
    sh:message "sh:message should be a language-tagged string (@en) in ERA shapes." .
