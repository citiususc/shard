@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix m8g: <http://data.europa.eu/m8g/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

epo:Business a owl:Class ;
    skos:definition "A private law company registered in a national registry."@en ;
    skos:historyNote "WG Approval 28/04/2020"@en ;
    skos:prefLabel "Business"@en .

epo:Buyer a owl:Class ;
    rdfs:subClassOf epo:AcquiringParty ;
    skos:definition "A Role of an Agent that awards a Contract and/or purchases items. Additional information: In Public Procurement the Role of Buyer is carried out by the following types of Organisation: Contracting Authority, Contracting Entity, a defense Contractor, an international Organisation, or an organisation awarding a Contract subsidized by a Contracting Authority. In Pre-Award, the Buyer generally awards the Contract, however future purchasers may be foreseen. In Post-Award the buyer generally refers to the purchaser of items."@en ;
    skos:prefLabel "Buyer"@en .

epo:Contract a owl:Class ;
    skos:definition "A voluntary, deliberate, and legally binding agreement between two or more competent parties."@en ;
    skos:historyNote "WG approval 19/03/2024"@en ;
    skos:prefLabel "Contract"@en .

epo:ESPD a owl:Class ;
    rdfs:subClassOf epo:Document ;
    skos:definition "A self-declaration of an economic operator, stating that it does not fall under the Exclusion Grounds and that it meets the Selection Criteria for a specific procurement."@en ;
    skos:historyNote "WG Approval 05/03/2024"@en ;
    skos:prefLabel "ESPD"@en .

epo:Item a owl:Class ;
    rdfs:subClassOf epo:AbstractItem ;
    skos:definition "A product, work, service or any combination of them. Additional Information: An Item can be an atomic Thing or a composition of things that together are seen as a unit, e.g. a tetrabrik of milk or an indivisible package of six tetrabriks. No distinction is provided between services, goods and works to leave room for innovation. An Item is used to fulfill a need which is described in an Item Request."@en ;
    skos:historyNote "WG approval 09/10/2025"@en ;
    skos:prefLabel "Item"@en .

epo:announcesProcedure a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:PlanningNotice epo:DirectAwardPrenotificationNotice epo:CompetitionNotice ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:CompetitionNotice epo:DirectAwardPrenotificationNotice epo:PlanningNotice ) ] ;
    rdfs:range epo:Procedure ;
    rdfs:subPropertyOf epo:concernsProcedure ;
    skos:definition "Relation indicating the formal communication of a Procedure."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "announces Procedure"@en .

epo:answersReviewRequest a owl:ObjectProperty ;
    rdfs:domain epo:ReviewDecision ;
    rdfs:range epo:ReviewRequest ;
    skos:definition "Responds to a Review Request."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "answers Review Request"@en .

epo:comprisesOrderResponseLine a owl:ObjectProperty ;
    rdfs:domain epo:OrderResponse ;
    rdfs:range epo:OrderResponseLine ;
    skos:definition "Incorporates Order Response Line."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "comprises Order Response Line"@en .

epo:concernsEnergyEfficiencyItemCategory a owl:ObjectProperty ;
    rdfs:domain epo:EnergyEfficiencyInformation ;
    rdfs:range skos:Concept ;
    skos:definition "Relates to Energy Efficiency Item Category."@en ;
    skos:prefLabel "concerns Energy Efficiency Item Category"@en .

epo:concernsNotice a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:NonPublishedInformation epo:ChangeInformation ) ] ;
    rdfs:range epo:Notice ;
    skos:definition "Relates to Notice."@en ;
    skos:historyNote "WG Approval 14/05/2024"@en ;
    skos:prefLabel "concerns Notice"@en .

epo:containsCandidate a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:SelectedCandidateList epo:ExcludedCandidateList ) ],
        epo:ExcludedCandidateList ;
    rdfs:range epo:Candidate ;
    skos:definition "Includes Candidate."@en ;
    skos:historyNote "WG Approval 14/05/2024"@en ;
    skos:prefLabel "contains Candidate"@en .

epo:describesItem a owl:ObjectProperty ;
    rdfs:domain epo:ItemProperty ;
    rdfs:range epo:AbstractItem ;
    skos:definition "Characterises Item."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "describes Item"@en .

epo:evaluatesProcurementCriterion a owl:ObjectProperty ;
    rdfs:domain epo:EvaluationCriterion ;
    rdfs:range epo:ProcurementCriterion ;
    skos:definition "Assesses Procurement Criterion."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "evaluates Procurement Criterion"@en .

epo:foreseesSubcontracting a owl:ObjectProperty ;
    rdfs:domain epo:Tender ;
    rdfs:range epo:SubcontractingEstimate ;
    skos:definition "Relation indicating that an instance of the concept plans to be Subcontracted."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "foresees Subcontracting"@en .

epo:hasAcceptanceStatus a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:AbstractContainer epo:ReceiptAdviceInformation ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:ReceiptAdviceInformation epo:AbstractContainer ) ] ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the acceptance status."@en ;
    skos:prefLabel "has Acceptance Status"@en .

epo:hasActualDeliveryDate a owl:DatatypeProperty ;
    rdfs:domain epo:DeliveryInformation ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date when the Delivery occured. (epo-ord:DeliveryInformation)"@en ;
    skos:historyNote "WG approval 25/09/2026"@en ;
    skos:prefLabel "has Actual Delivery Date"@en .

epo:hasBuyerItemID a owl:ObjectProperty ;
    rdfs:domain epo:AbstractItem ;
    rdfs:range adms:Identifier ;
    skos:definition "The general identifier assigned to the concept as defined by the Buyer.​"@en ;
    skos:historyNote "WG Approval 16/05/2023"@en ;
    skos:prefLabel "has Buyer Item ID"@en .

epo:hasCalculationBasedOn a owl:ObjectProperty ;
    rdfs:domain epo:EnergyEfficiencyInformation ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the basis for the calculation of the energy efficiency."@en ;
    skos:prefLabel "has Calculation Based On"@en .

epo:hasDespatchedQuantity a owl:ObjectProperty ;
    rdfs:domain epo:DespatchLine ;
    rdfs:range epo:Quantity ;
    skos:definition "The Quantity that has been sent."@en ;
    skos:historyNote "WG Approval 18/06/2024"@en ;
    skos:prefLabel "has Despatched Quantity"@en .

epo:hasDocumentType a owl:ObjectProperty ;
    rdfs:domain epo:Document ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the Document Type."@en ;
    skos:prefLabel "has Document Type"@en .

epo:hasElementReference a owl:DatatypeProperty ;
    rdfs:domain epo:ReviewInformation ;
    rdfs:range xsd:anyURI ;
    skos:definition "Reference to the class instance in the current notice. (epo:ReviewInformation)"@en ;
    skos:editorialNote "Used by eForms BT-13716, eForms BT-786, eForms BT-1501"@en ;
    skos:prefLabel "has Element Reference"@en .

epo:hasEnvironmentalEmissionCode a owl:ObjectProperty ;
    rdfs:domain epo:EnvironmentalEmissionInformation ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the Environmental Emission Code."@en ;
    skos:prefLabel "has Environmental Emission Code"@en .

epo:hasFormula a owl:DatatypeProperty ;
    rdfs:domain epo:ProcurementCriterion ;
    rdfs:range rdf:PlainLiteral ;
    skos:definition "The mathematical equation or any other description used for complicated weighing of criteria (e.g. non-linear weighing, the analytic hierarchy process) when a weighing cannot be expressed per criterion. (epo:ProcurementCriterion)"@en ;
    skos:editorialNote "Used by eForms BT-543"@en ;
    skos:prefLabel "has Formula"@en .

epo:hasItemClassification a owl:ObjectProperty ;
    rdfs:domain epo:AbstractItem ;
    rdfs:range skos:Concept ;
    skos:definition "A classification of this item according to a specific system for classifying products or services. Additional information: Examples of classification schemes are: CPV, UNSPC, eCl@ss, GPC, ..."@en ;
    skos:prefLabel "has Item Classification"@en .

epo:hasMaximumMeasure a owl:ObjectProperty ;
    rdfs:domain epo:DimensionInformation ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the upper limit of the measure."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Maximum Measure"@en .

epo:hasMaximumNumberOfCandidates a owl:DatatypeProperty ;
    rdfs:domain epo:MultipleStageProcedureTerm ;
    rdfs:range xsd:integer ;
    skos:definition "Maximum number of candidates to be invited for the second stage of the procedure. (epo:MultipleStageProcedureTerm)"@en ;
    skos:historyNote "WG Approval 22/08/2019"@en ;
    skos:prefLabel "has Maximum Number Of Candidates"@en .

epo:hasMeasuredAttributeCode a owl:ObjectProperty ;
    rdfs:domain epo:DimensionInformation ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the Measured Attribute Code."@en ;
    skos:prefLabel "has Measured Attribute Code"@en .

epo:hasMinimumMeasure a owl:ObjectProperty ;
    rdfs:domain epo:DimensionInformation ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the lower limit of the measure."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Minimum Measure"@en .

epo:hasMinimumNumberOfCandidates a owl:DatatypeProperty ;
    rdfs:domain epo:MultipleStageProcedureTerm ;
    rdfs:range xsd:integer ;
    skos:definition "Minimum number of candidates to be invited for the second stage of the procedure. (epo:MultipleStageProcedureTerm)"@en ;
    skos:historyNote "WG Approval 22/08/2019"@en ;
    skos:prefLabel "has Minimum Number Of Candidates"@en .

epo:hasNetQuantity a owl:ObjectProperty ;
    rdfs:domain epo:AbstractItem ;
    rdfs:range epo:Quantity ;
    skos:definition "The net quantity of the item that is contained in each consumable unit, excluding any packaging materials."@en ;
    skos:prefLabel "has Net Quantity"@en .

epo:hasNoticeType a owl:ObjectProperty ;
    rdfs:domain epo:Notice ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the Notice Type."@en ;
    skos:prefLabel "has Notice Type"@en .

epo:hasOutstandingQuantity a owl:ObjectProperty ;
    rdfs:domain epo:DespatchLine ;
    rdfs:range epo:Quantity ;
    skos:definition "The Quantity of non-despatched Goods Items."@en ;
    skos:historyNote "WG Approval 05/06/2024"@en ;
    skos:prefLabel "has Outstanding Quantity"@en .

epo:hasProcedureType a owl:ObjectProperty ;
    rdfs:domain epo:Procedure ;
    rdfs:range skos:Concept ;
    skos:definition "Identification of the Procedure used."@en ;
    skos:prefLabel "has Procedure Type"@en .

epo:hasPublicationDate a owl:DatatypeProperty ;
    rdfs:domain epo:Document ;
    rdfs:range xsd:date ;
    skos:definition "Date of formal public issuance of the document. (epo:Document)"@en ;
    skos:historyNote "WG approval 20/06/2023"@en ;
    skos:prefLabel "has Publication Date"@en .

epo:hasQuantity a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:OrderLine epo:InvoiceLine epo:Deliverable ) ],
        epo:Deliverable,
        epo:InvoiceLine,
        epo:OrderLine ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating that the instance of the concept has a Quantity."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Quantity"@en .

epo:hasResponseStatus a owl:ObjectProperty ;
    rdfs:domain epo:CatalogueResponseInformation ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the response status."@en ;
    skos:prefLabel "has Response Status"@en .

epo:hasReviewDecisionType a owl:ObjectProperty ;
    rdfs:domain epo:ReviewDecision ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the Review Decision Type."@en ;
    skos:prefLabel "has Review Decision Type"@en .

epo:hasReviewRequestFee a owl:ObjectProperty ;
    rdfs:domain epo:ReviewRequest ;
    rdfs:range epo:MonetaryValue ;
    skos:definition "Relation indicating the charge or cost required for processing the Review Request."@en ;
    skos:editorialNote "Used by eForms BT-795"@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Review Request Fee"@en .

epo:hasStatus a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:OrderResponseInformation epo:OrderChangeLine ) ] ;
    rdfs:range skos:Concept ;
    skos:definition "Relation indicating the status."@en ;
    skos:prefLabel "has Status"@en .

epo:includesNationalCriterion a owl:ObjectProperty ;
    rdfs:domain epo:QualificationCriterion ;
    rdfs:range epo:QualificationCriterion ;
    skos:definition "Relation indicating that a Criterion contains a Criterion that is specific to a given Member State."@en ;
    skos:historyNote "WG approval 07/11/2023"@en ;
    skos:prefLabel "includes National Criterion"@en .

epo:isSpecificToOrderResponseLine a owl:ObjectProperty ;
    rdfs:domain epo:OrderResponseInformation ;
    rdfs:range epo:OrderResponseLine ;
    skos:definition "Information that is particular to an Order Response Line."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "is Specific To Order Response Line"@en .

epo:refersToNotice a owl:ObjectProperty ;
    rdfs:domain epo:ESPDRequest,
        epo:Notice ;
    rdfs:range epo:Notice ;
    skos:definition "Reference to a Notice."@en ;
    skos:historyNote "WG approval 12/03/2024"@en,
        "WG approval 25/09/2025"@en ;
    skos:prefLabel "refers To Notice"@en .

<https://github.com/citiususc/shard/tree/main/frontend/examples/epo-5.2.0-shard-demo-subset> a owl:Ontology ;
    dcterms:description "A reduced, domain-coherent subset of ePO 5.2.0 prepared for the preloaded SHARD Rule-to-Shape and Batch-to-Shapes demonstrations."@en ;
    dcterms:license <https://joinup.ec.europa.eu/collection/eupl/eupl-text-eupl-12> ;
    dcterms:publisher <http://publications.europa.eu/resource/authority/corporate-body/PUBL> ;
    dcterms:source epo: ;
    dcterms:title "ePO 5.2.0 SHARD demonstration subset"@en ;
    vann:preferredNamespacePrefix "epo" ;
    vann:preferredNamespaceUri epo: ;
    rdfs:seeAlso <https://github.com/OP-TED/ePO/releases> ;
    owl:versionInfo "5.2.0" .

epo:AcquiringParty a owl:Class ;
    rdfs:subClassOf epo:AgentInRole ;
    skos:definition "The Role of an Agent that acts on the buying side of a Procurement Process."@en ;
    skos:prefLabel "Acquiring Party"@en .

epo:AwardOutcome a owl:Class ;
    rdfs:subClassOf epo:ContextualProjection ;
    skos:definition "Result concerning the competition that was attributed by the Awarder."@en ;
    skos:historyNote "WG approval 19/03/2024"@en ;
    skos:prefLabel "Award Outcome"@en .

epo:Candidate a owl:Class ;
    rdfs:subClassOf epo:OfferingParty ;
    skos:definition "The Role of an Agent that has sought an invitation or has been invited to take part in a restricted Procedure, in a competitive Procedure with negotiation, in a negotiated Procedure without prior publication, in a competitive dialogue or in an innovation partnership."@en ;
    skos:historyNote "WG approval 30/05/2023"@en ;
    skos:prefLabel "Candidate"@en .

epo:CatalogueResponseInformation a owl:Class ;
    skos:definition "Information about a Catalogue Response."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Catalogue Response Information"@en .

epo:ConcessionEstimate a owl:Class ;
    rdfs:subClassOf epo:Estimate,
        epo:MaskableObject ;
    skos:definition "Approximation concerning the foreseen Concession Contract."@en ;
    skos:historyNote "WG approval 19/03/2024"@en ;
    skos:prefLabel "Concession Estimate"@en .

epo:ContextualProjection a owl:Class ;
    skos:definition "Projection of an Entity and all of its properties that hold in a given Situation Context. Additional Information: The contextual projection does not have its own identity (-I), is dependent (+D) on the described Entity, and is anti-rigid (~R) We say that ContextualProjection *describes* an Entity. Adaptation of ContextSlices pattern encoding a 4D view. http://ontologydesignpatterns.org/wiki/Submissions:Context_Slices"@en ;
    skos:prefLabel "Contextual Projection"@en .

epo:ContractLotCompletionInformation a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Information related to a given Lot at the end of the procurement."@en ;
    skos:prefLabel "Contract Lot Completion Information"@en .

epo:DeliveryInformation a owl:Class ;
    rdfs:subClassOf epo:InformationHub ;
    skos:definition "Information about the timing, the delivery destination, the delivery agreement and the involved parties."@en ;
    skos:historyNote "WG Approval 16/05/2023"@en ;
    skos:prefLabel "Delivery Information"@en .

epo:EvaluationCriterion a owl:Class ;
    skos:definition "A Criterion used by the Buyer to assess and compare Tenders in order to determine which Offer best meets the objectives of the Procurement Procedure."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Evaluation Criterion"@en .

epo:ExpressionOfInterest a owl:Class ;
    skos:definition "Document presenting an Economic Operator's Request to be considered for Procedures covering a specific domain."@en ;
    skos:historyNote "WG approval 13/04/2021"@en ;
    skos:prefLabel "Expression Of Interest"@en .

epo:ItemProperty a owl:Class ;
    skos:definition "Construct meant to represent the association between an attribute defined in an external classification scheme and the value ascribed to it."@en ;
    skos:historyNote "WG Approval 26/07/2022"@en ;
    skos:prefLabel "Item Property"@en .

epo:Lot a owl:Class ;
    rdfs:subClassOf epo:ProcurementObject ;
    skos:definition "A qualitative, quantitative or strategic subdivision of the goods, services or works to be procured, allowing the award of one or more Contracts."@en ;
    skos:historyNote "WG approval 12/09/2018"@en ;
    skos:prefLabel "Lot"@en .

epo:LotAwardOutcome a owl:Class ;
    rdfs:subClassOf epo:AwardOutcome,
        epo:MaskableObject ;
    skos:definition "Result concerning the Lot that was attributed by the Awarder."@en ;
    skos:historyNote "WG Approval 19/03/2024"@en ;
    skos:prefLabel "Lot Award Outcome"@en .

epo:LotGroup a owl:Class ;
    skos:definition "Combination of several Lots to conduct comparative assessment of the Tenders. Additional Information: The comparative assessment may refer to the Selection Criteria, Award and Value that apply to several Lots. Pending of discussion with eForms Member States may provide that, where more than one lot may be awarded to the same tenderer, contracting authorities may award contracts combining several or all lots where they have specified in the contract notice or in the invitation to confirm interest that they reserve the possibility of doing so and indicate the lots or groups of lots that may be combined."@en ;
    skos:prefLabel "Lot Group"@en .

epo:MonetaryValue a owl:Class ;
    rdfs:subClassOf epo:MaskableObject ;
    skos:definition "A number of monetary units specified using a given unit of currency. Additional information: In the pre-award phase of the procurement, all monetary values are considered to exclude VAT based on the Directive 2014/24/EU."@en ;
    skos:historyNote "WG approval 13/04/2021"@en ;
    skos:prefLabel "Monetary Value"@en .

epo:NonPublishedInformation a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Information about fields not published in this Notice. Additional Information: The non-published information may become available at a later date and may differ from one element to another within a given Document. Examples of fields that may not be immediately published are Winner, Tender and Procedure Lot Result, etc., e.g. for security reasons."@en ;
    skos:prefLabel "Non Published Information"@en .

epo:Order a owl:Class ;
    rdfs:subClassOf epo:PostAwardDocument ;
    skos:definition "A formal request of the Buyer to the Seller specifying the goods, services or works to be delivered. Additional Information: A Buyer submits an Order for delivery of goods, services or works to a Seller."@en ;
    skos:historyNote "WG Approval 23/04/2023"@en ;
    skos:prefLabel "Order"@en .

epo:OrderChangeLine a owl:Class ;
    rdfs:subClassOf epo:OrderLine ;
    skos:definition "Details concerning a given unit of goods, services or works requested in the Order Change."@en ;
    skos:historyNote "WG approval 16/09/2025"@en ;
    skos:prefLabel "Order Change Line"@en .

epo:OrderResponse a owl:Class ;
    rdfs:subClassOf epo:Order ;
    skos:definition "A formal reply from the Seller to the Buyer stating the Seller's ability to fulfil the order. Additional Information: The Order Response is used to inform on the acceptance or rejection of an Order or to make a counter-offer."@en ;
    skos:historyNote "WG Approval 20/04/2023"@en ;
    skos:prefLabel "Order Response"@en .

epo:PostAwardDocument a owl:Class ;
    rdfs:subClassOf epo:Document ;
    skos:definition "Document created after the award of a Contract during a Procurement Procedure."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Post Award Document"@en .

epo:ProcurementDocument a owl:Class ;
    skos:definition "Document produced or referred to by the Buyer to describe or determine elements of the Procurement. Additional information: Procurement Documents are to be accessible since the date of publication of the Contract Notice or the prior information Notice when used as a call for competition. Examples of Procurement Documents are Technical Specifications, the Descriptive Document, proposed conditions of Contract, formats for the presentation of Documents by Candidates and Tenderers, information on generally applicable obligations. Other Documents related to the Procedure such as Notices are not considered to be Procurement Documents."@en ;
    skos:historyNote "WG Approval 23/05/2019"@en ;
    skos:prefLabel "Procurement Document"@en .

epo:SubcontractingEstimate a owl:Class ;
    rdfs:subClassOf epo:Estimate,
        epo:MaskableObject ;
    skos:definition "Approximation concerning the foreseen Subcontracting."@en ;
    skos:historyNote "WG approval 19/03/2024"@en ;
    skos:prefLabel "Subcontracting Estimate"@en .

epo:Tender a owl:Class ;
    rdfs:subClassOf epo:MaskableObject ;
    skos:definition "Information submitted by the Economic Operator to specify its Offer regarding a specific Lot, in response to the call for Tender."@en ;
    skos:historyNote "WG approval 03/05/2022"@en ;
    skos:prefLabel "Tender"@en .

epo:Term a owl:Class ;
    skos:definition "A governing condition or stipulation."@en ;
    skos:prefLabel "Term"@en .

epo:TransportMeans a owl:Class ;
    skos:definition "Description of a particular vehicle or vessel used for the conveyance of goods or persons."@en ;
    skos:historyNote "WG Approval 21/05/2024"@en ;
    skos:prefLabel "Transport Means"@en .

epo:Winner a owl:Class ;
    rdfs:subClassOf epo:OfferingParty ;
    skos:definition "A Role of an Agent to whom a Lot is awarded."@en ;
    skos:historyNote "WG Approval 26/10/2021"@en ;
    skos:prefLabel "Winner"@en .

epo:concernsItem a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:DimensionInformation epo:EnvironmentalEmissionInformation ) ] ;
    rdfs:range epo:AbstractItem ;
    skos:definition "Relates to Item."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "concerns Item"@en .

epo:concernsLot a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:CompletionNotice epo:ContractModificationNotice epo:ContractLotCompletionInformation epo:ResultNotice epo:ProcurementProcessInformation epo:LotAwardOutcome m8g:InformationRequirement epo:EvidenceRequest epo:EvidenceSubmission ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:EvidenceSubmission epo:EvidenceRequest ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:CompletionNotice epo:ContractModificationNotice epo:ResultNotice ) ] ;
    rdfs:range epo:Lot ;
    skos:definition "Relates to Lot."@en ;
    skos:prefLabel "concerns Lot"@en .

epo:concernsReviewDecision a owl:ObjectProperty ;
    rdfs:domain epo:ReviewInformation ;
    rdfs:range epo:ReviewDecision ;
    skos:definition "Relates to Review Decision."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "concerns Review Decision"@en .

epo:concernsReviewRequest a owl:ObjectProperty ;
    rdfs:domain epo:ReviewInformation ;
    rdfs:range epo:ReviewRequest ;
    skos:definition "Relates to Review Request."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "concerns Review Request"@en .

epo:foreseesSubcontractor a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( org:Organization epo:Contractor ) ] ;
    rdfs:range epo:Subcontractor ;
    skos:definition "Relation indicating that an Organization plans to have a Subcontractor. Additional information: In eForms, in a Result Notice, the foreseen Subcontractors in a Tender are associated to the Organization that proposes the Subcontractors. The Subcontractor is associated to the Organization, rather than the Tenderer, so that, in the case of multiple Organizations being a Tenderer, it is clear to which Organization the proposed Subcontractor is associated."@en ;
    skos:historyNote "WG Approval 26/11/2024"@en ;
    skos:prefLabel "foresees Subcontractor"@en .

epo:hasAdditionalInformation a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:ProcurementElement epo:ProcurementCriterion epo:Document epo:ChangeInformation ) ],
        epo:Line ;
    rdfs:range rdf:PlainLiteral ;
    skos:definition "Supplementary data about the instance of the concept. (epo-cat:Line)"@en,
        "Supplementary data about the instance of the concept. (epo:ProcurementElement) Supplementary data about the instance of the concept. (epo:ProcurementCriterion) Supplementary data about the instance of the concept. (epo:Document) Supplementary data about the instance of the concept. (epo:ChangeInformation)"@en ;
    skos:editorialNote "Used by eforms BT-300"@en ;
    skos:historyNote "WG Approval 15/10/2019"@en ;
    skos:prefLabel "has Additional Information"@en .

epo:hasBestBeforeDate a owl:DatatypeProperty ;
    rdfs:domain epo:Batch ;
    rdfs:range xsd:date ;
    skos:definition "The day until which the quality of the item will remain optimal. (epo-cat:Batch)"@en ;
    skos:historyNote "WG Approval 10/03/2021"@en ;
    skos:prefLabel "has Best Before Date"@en .

epo:hasCalculationMethod a owl:DatatypeProperty ;
    rdfs:domain epo:ConcessionEstimate,
        epo:EnvironmentalEmissionInformation ;
    rdfs:range rdf:PlainLiteral ;
    skos:definition "Formula for obtaining values. Additional Information: The possible values are monetary values, ranking scores, criterion weighting. (epo-cat:EnvironmentalEmissionInformation)"@en,
        "Formula for obtaining values. Additional Information: The possible values are monetary values, ranking scores, criterion weighting. (epo:ConcessionEstimate)"@en ;
    skos:historyNote "WG Approval 25/05/2018"@en ;
    skos:prefLabel "has Calculation Method"@en .

epo:hasExpiryDate a owl:DatatypeProperty ;
    rdfs:domain epo:Batch ;
    rdfs:range xsd:date ;
    skos:definition "The last day until which the item can be used. (epo-cat:Batch)"@en ;
    skos:historyNote "WG Approval 10/03/2021"@en ;
    skos:prefLabel "has Expiry Date"@en .

epo:hasManufactureDate a owl:DatatypeProperty ;
    rdfs:domain epo:Batch ;
    rdfs:range xsd:dateTime ;
    skos:definition "The day of production. (epo-cat:Batch)"@en ;
    skos:prefLabel "has Manufacture Date"@en .

epo:hasQualificationCriteriaStatedInESPDRequest a owl:DatatypeProperty ;
    rdfs:domain epo:QualificationCriterion ;
    rdfs:range xsd:boolean ;
    skos:definition "The Qualification Criteria is specified in the ESPD Request. (epo:QualificationCriterion)"@en ;
    skos:historyNote "WG approval 09/09/2025"@en ;
    skos:prefLabel "has Qualification Criteria Stated In ESPD Request"@en .

epo:hasQualificationCriteriaStatedInNotice a owl:DatatypeProperty ;
    rdfs:domain epo:QualificationCriterion ;
    rdfs:range xsd:boolean ;
    skos:definition "The Qualification Criteria is specified in the Notice. (epo:QualificationCriterion)"@en ;
    skos:historyNotice "WG approval 09/09/2025"@en ;
    skos:prefLabel "has Qualification Criteria Stated In Notice"@en .

epo:hasQualificationCriteriaStatedInProcurementDocuments a owl:DatatypeProperty ;
    rdfs:domain epo:QualificationCriterion ;
    rdfs:range xsd:boolean ;
    skos:definition "The Qualification Criteria is specified in the Procurement Documents. (epo:QualificationCriterion)"@en ;
    skos:historyNote "WG approval 09/09/2025"@en ;
    skos:prefLabel "has Qualification Criteria Stated In Procurement Documents"@en .

epo:hasStartDate a owl:ObjectProperty ;
    rdfs:domain epo:SelectedCandidateList ;
    rdfs:range time:Interval ;
    skos:definition "Relation indicating the beginning date."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Start Date"@en .

epo:hasSubcontractor a owl:ObjectProperty ;
    rdfs:domain epo:Contractor ;
    rdfs:range epo:Subcontractor ;
    skos:definition "Relation indicating the Subcontractor."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Subcontractor"@en .

epo:isCompetitionTerminated a owl:DatatypeProperty ;
    rdfs:domain epo:ProcurementProcessInformation ;
    rdfs:range xsd:boolean ;
    skos:definition "No further contracts will be awarded in this procedure. Additional Information: This can be instantiated in the post award phase. PIN for Competition needs to be signaled. This field can be used even if no contracts are awarded in the contract award notice. (epo:ProcurementProcessInformation)"@en ;
    skos:editorialNote "Used by eForms BT-756"@en ;
    skos:prefLabel "is Competition Terminated"@en .

epo:isDPSTerminated a owl:DatatypeProperty ;
    rdfs:domain epo:ProcurementProcessInformation ;
    rdfs:range xsd:boolean ;
    skos:definition "End of the Dynamic Purchase System (DPS). Additional Information: This property can be used in the contract award notice even if no contracts are awarded. (epo:ProcurementProcessInformation)"@en ;
    skos:historyNote "WG Approval 22/11/2019"@en ;
    skos:prefLabel "is DPS Terminated"@en .

epo:isProductionOf a owl:ObjectProperty ;
    rdfs:domain epo:Batch ;
    rdfs:range epo:AbstractItem ;
    skos:definition "Relation indicating the Item that is manufactured."@en ;
    skos:prefLabel "is Production Of"@en .

epo:isSubmittedForDespatchLine a owl:ObjectProperty ;
    rdfs:domain epo:ReceiptAdviceLine ;
    rdfs:range epo:DespatchLine ;
    skos:definition "Relation indicating that the instance of the concept is sent for a specific Despatch Line."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "is Submitted For Despatch Line"@en .

epo:isToBeRelaunched a owl:DatatypeProperty ;
    rdfs:domain epo:ProcurementProcessInformation ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicator of whether the procurement object is to be relaunched. Additional information: This can be instantiated in the post award phase. (epo:ProcurementProcessInformation)"@en ;
    skos:editorialNote "Used by eForms BT-634"@en ;
    skos:historyNote "WG Approval 18/01/2022"@en ;
    skos:prefLabel "is To Be Relaunched"@en .

epo:needsToBeAWinner a owl:ObjectProperty ;
    rdfs:domain epo:Contractor ;
    rdfs:range epo:Winner ;
    skos:definition "The Contractor must be a Winner."@en ;
    skos:prefLabel "needs To Be A Winner"@en .

epo:relatesToEFormSectionIdentifier a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:ReviewInformation epo:ChangeInformation epo:ContractModificationInformation ) ],
        epo:ContractModificationInformation ;
    rdfs:range adms:Identifier ;
    skos:definition "Is about a specific eForms section."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "relates To E Form Section Identifier"@en .

epo:specifiesItem a owl:ObjectProperty ;
    rdfs:domain epo:Line ;
    rdfs:range epo:AbstractItem ;
    skos:definition "Relation indicating the Item."@en ;
    skos:prefLabel "specifies Item"@en .

epo:AbstractContainer a owl:Class ;
    skos:definition "Gathering class for Packages and Transport Handling Units."@en ;
    skos:historyNote "WG Approval 14/05/2024"@en ;
    skos:prefLabel "Abstract Container"@en .

epo:AgentInRole a owl:Class ;
    skos:definition "Relative concept that ties an Agent to a part they play in a given Situational Context. Additional information: The classification of roles is based is based on the degree of involvement into the Procurement Process: - Primary (Procurement) Pole is directly involved in the Procurement Process; - Secondary (Procurement sub-) Role is secondary to the Procurement Process - Tertiary (Related) Role is not involved in the Procurement Process."@en ;
    skos:prefLabel "Agent In Role"@en .

epo:AwardDecisionNotification a owl:Class ;
    rdfs:subClassOf epo:Document ;
    skos:definition "A formal communication sent by the Buyer to inform Tenderers of the Award Decision."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Award Decision Notification"@en .

epo:CompetitionNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "An announcement of the launch of a Procurement Procedure by a Procuring Entity."@en ;
    skos:historyNote "WG Approval 18/05/2018"@en ;
    skos:prefLabel "Competition Notice"@en .

epo:ContractModificationInformation a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Information about a Contract Amendment."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Contract Modification Information"@en .

epo:Deliverable a owl:Class ;
    rdfs:subClassOf epo:AbstractItem ;
    skos:definition "Item that the supplier is obligated to provide under a contract."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Deliverable"@en .

epo:DirectAwardPrenotificationNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "Notice which sets out the Buyer's purchasing intention to award a Contract without prior notification of Competition."@en ;
    skos:prefLabel "Direct Award Prenotification Notice"@en .

epo:EnergyEfficiencyInformation a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Information about the energy performance, consumption, or sustainability characteristics of a product, service, building, or process relevant to the execution or evaluation of a procurement procedure."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Energy Efficiency Information"@en .

epo:Estimate a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "An approximate calculation or a judgement of the value, number, Quantity or extent of something."@en ;
    skos:prefLabel "Estimate"@en .

epo:ExcludedCandidateList a owl:Class ;
    skos:definition "Record of Candidates prevented from participating in a Procurement because one or more Exclusion Grounds apply."@en ;
    skos:historyNote "WG approval 16/09/2025"@en ;
    skos:prefLabel "Excluded Candidate List"@en .

epo:InvoiceLine a owl:Class ;
    rdfs:subClassOf epo:Line ;
    skos:definition "Details concerning a given unit of goods, services or works mentioned in the Invoice."@en ;
    skos:historyNote "WG Approval 11/07/2024"@en ;
    skos:prefLabel "Invoice Line"@en .

epo:MultipleStageProcedureTerm a owl:Class ;
    rdfs:subClassOf epo:Term ;
    skos:definition "Conditions and stipulations defining particularities of Procedures carried out in several steps Additional Information: Generally this refers to Procedures where selection is carried out to qualify Tenderers who are then requested to submit the rest of their Tender for evaluation is Restricted Procedure."@en ;
    skos:historyNote "WG Approval 15/04/2021"@en ;
    skos:prefLabel "Multiple Stage Procedure Term"@en .

epo:OrderResponseInformation a owl:Class ;
    rdfs:subClassOf epo:InformationHub ;
    skos:definition "Information about an Order Response."@en ;
    skos:historyNote "WG approval 16/09/2025"@en ;
    skos:prefLabel "Order Response Information"@en .

epo:OrderResponseLine a owl:Class ;
    rdfs:subClassOf epo:OrderLine ;
    skos:definition "Details concerning the Seller's ability to fulfil a given Order Line. Additional Information: The Order Response Line is used to inform on the acceptance or rejection of an Order Line or to make a counter-offer."@en ;
    skos:historyNote "WG Approval 20/04/2023"@en ;
    skos:prefLabel "Order Response Line"@en .

epo:PlanningNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "Notice which sets out the Contracting Authority's purchasing intentions. It is used by Contracting Authorities to provide Suppliers with information about a Procurement Process."@en ;
    skos:prefLabel "Planning Notice"@en .

epo:ProcurementObject a owl:Class ;
    rdfs:subClassOf epo:MaskableObject,
        epo:ProcurementElement ;
    skos:definition "The whole or a division of goods, services or works to be procured. Additional Information: Anything that can specify the procurement content (i.e. goods, services, work) is a Procurement Object. In a sense, such an \"object\" can constitute the \"object of a Contract\". To test whether something is a Procedure Object check if it can have a Purpose and/or CPV classification (<i>The CPV establishes a single classification system for public procurement aimed at standardising the references used by Contracting Authorities and entities to describe the subject of Procurement Contracts.</i>). Note: Procedure, seems to be an exception from this rule. Because it is a conflated term: it carries process properties and \"purpose\" properties."@en ;
    skos:prefLabel "Procurement Object"@en .

epo:ReceiptAdviceInformation a owl:Class ;
    rdfs:subClassOf epo:InformationHub ;
    skos:definition "Information about the Receipt Advice."@en ;
    skos:historyNote "WG approval 16/09/2025"@en ;
    skos:prefLabel "Receipt Advice Information"@en .

epo:SelectedCandidateList a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasStartDate ] ;
    skos:definition "Record of Candidates admitted to take part in award phases of procurements."@en ;
    skos:historyNote "WG approval 30/05/2023"@en ;
    skos:prefLabel "Selected Candidate List"@en .

epo:Subcontractor a owl:Class ;
    rdfs:subClassOf epo:OfferingParty ;
    skos:definition "A Role of an Agent that has an agreement to perform part or all of the obligations of another Agents's Contract. Additional information For some Procedures, the Subcontractor signs as well the Contract between the Buyer and the Contractor. At tendering time, entities relied upon by the Economic Operators can be Subcontractors or not. When modelling ESPD we will analyze whether we need or not a Role named \"relied upon\"."@en ;
    skos:historyNote "WG approval 05/08/2021"@en ;
    skos:prefLabel "Subcontractor"@en .

epo:concernsTransportMeans a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:EnvironmentalEmissionInformation epo:DimensionInformation ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:DimensionInformation epo:EnvironmentalEmissionInformation ) ] ;
    rdfs:range epo:TransportMeans ;
    skos:definition "Relates to Transport Means."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "concerns Transport Means"@en .

epo:hasAssociatedDocument a owl:ObjectProperty ;
    rdfs:domain epo:Line ;
    rdfs:range epo:Document ;
    skos:definition "Is related to a Document."@en ;
    skos:historyNote "WG Approval 06/10/2024"@en ;
    skos:prefLabel "has Associated Document"@en .

epo:hasBatchID a owl:ObjectProperty ;
    rdfs:domain epo:Batch ;
    rdfs:range adms:Identifier ;
    skos:definition "The identifier assigned to a specific batch of the produced Item."@en ;
    skos:historyNote "WG Approval 16/05/2023"@en ;
    skos:prefLabel "has Batch ID"@en .

epo:hasMeasure a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:DimensionInformation epo:EnvironmentalEmissionInformation ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:DimensionInformation epo:EnvironmentalEmissionInformation ) ] ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the unit used for stating the size."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Measure"@en .

epo:hasOversupplyQuantity a owl:ObjectProperty ;
    rdfs:domain epo:ReceiptAdviceLine ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the Quantity surplus."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Oversupply Quantity"@en .

epo:hasReceivedQuantity a owl:ObjectProperty ;
    rdfs:domain epo:ReceiptAdviceLine ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the delivered Quantity."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Received Quantity"@en .

epo:hasRejectedQuantity a owl:ObjectProperty ;
    rdfs:domain epo:ReceiptAdviceLine ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the non-accepted Quantity."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Rejected Quantity"@en .

epo:hasShortQuantity a owl:ObjectProperty ;
    rdfs:domain epo:ReceiptAdviceLine ;
    rdfs:range epo:Quantity ;
    skos:definition "Relation indicating the Quantity deficit."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "has Short Quantity"@en .

epo:specifiesProcurementCriterion a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:LotGroup epo:ProcurementElement epo:ESPDRequest ) ],
        epo:ESPDRequest ;
    rdfs:range epo:ProcurementCriterion ;
    skos:definition "Relation indicating the Procurement Criterion to be used."@en ;
    skos:historyNote "WG approval 25/09/2025"@en ;
    skos:prefLabel "specifies Procurement Criterion"@en .

epo:ChangeInformation a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Alteration to previously provided details."@en ;
    skos:prefLabel "Change Information"@en .

epo:Contractor a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:foreseesSubcontractor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasSubcontractor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:needsToBeAWinner ],
        epo:OfferingParty ;
    skos:definition "The Role of an Agent that has signed a Contract with a Buyer."@en ;
    skos:historyNote "WG approval 08/11/2022"@en ;
    skos:prefLabel "Contractor"@en .

epo:DespatchLine a owl:Class ;
    rdfs:subClassOf epo:Line ;
    skos:definition "Details concerning the fulfilment of an Order Line."@en ;
    skos:historyNote "WG Approval 21/05/2024"@en ;
    skos:prefLabel "Despatch Line"@en .

epo:InformationHub a owl:Class ;
    rdfs:subClassOf epo:ContextDescription ;
    skos:definition "Grouping of data that may be associated to various concepts. Additional Information: For example, AllowanceChargeInformation may be associated to the Order or the Catalogue (either at the Line level or at the Document level), amongst others."@en ;
    skos:historyNote "WG Approval 16/05/2023"@en ;
    skos:prefLabel "Information Hub"@en .

epo:Procedure a owl:Class ;
    rdfs:subClassOf epo:ProcurementObject ;
    skos:definition "A legally defined set of administrative activities conducted to conclude one or more Contracts. Additional Information The Procedure is categorised in the law according to different rules determining whether the Procedure is Open, Restricted, Negotiated with or without publicity, etc. (see Procedure Type)."@en ;
    skos:historyNote "WG Approval 20/08/2019"@en ;
    skos:prefLabel "Procedure"@en .

epo:ProcurementElement a owl:Class ;
    skos:definition "Gathering class for critical/central elements in the Procurement Process. TODO: add definition Additional information: Alias: ProcurementComponent"@en ;
    skos:prefLabel "Procurement Element"@en .

epo:ReviewDecision a owl:Class ;
    skos:definition "Information about Review Decisions."@en ;
    skos:prefLabel "Review Decision"@en .

epo:ReviewRequest a owl:Class ;
    skos:definition "Information about requests to review procedures."@en ;
    skos:historyNote "WG Approval 23/10/2021"@en ;
    skos:prefLabel "Review Request"@en .

epo:CompletionNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "An announcement of the end of a Procurement by a Buyer."@en ;
    skos:prefLabel "Completion Notice"@en .

epo:ContractModificationNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "An announcement of the Modification of a Contract/Concession during its term by a Procuring Entity."@en ;
    skos:prefLabel "Contract Modification Notice"@en .

epo:EvidenceRequest a owl:Class ;
    rdfs:subClassOf epo:Document ;
    skos:definition "A Document sent by the Buyer to the Economic Operator asking for the submission of an Evidence."@en ;
    skos:prefLabel "Evidence Request"@en .

epo:EvidenceSubmission a owl:Class ;
    rdfs:subClassOf epo:Document ;
    skos:definition "A Document sent by the Economic Operator to the Buyer which contains an Evidence."@en ;
    skos:prefLabel "Evidence Submission"@en .

epo:OfferingParty a owl:Class ;
    rdfs:subClassOf epo:AgentInRole ;
    skos:definition "The Role of an Agent that acts on the Economic Operator side during a Procurement Process. Additional information: As per the European Procurement Directives the notion of ‘Economic Operators’ should be interpreted in a broad manner so as to include any Persons and/or Entities which offer the execution of works, the supply of products or the provision of services on the market, irrespective of the legal form under which they have chosen to operate. Thus, firms, branches, subsidiaries, partnerships, cooperative societies, limited companies, universities, public or private, and other forms of entities than natural Persons should all fall within the notion of Economic Operator, whether or not they are ‘Legal Persons’ in all circumstances."@en ;
    skos:prefLabel "Offering Party"@en .

epo:OrderLine a owl:Class ;
    rdfs:subClassOf epo:Line ;
    skos:definition "Details concerning a given unit of goods, services or works requested in the Order. Additional information: In general, an Order Line contains the Quantity and Price of the goods, services and goods requested in the Order. However, in certain cases, the Price may not be known, as the Price may fluctuate from one day to the other."@en ;
    skos:historyNote "WG Approval 20/04/2023"@en ;
    skos:prefLabel "Order Line"@en .

epo:ResultNotice a owl:Class ;
    rdfs:subClassOf epo:Notice ;
    skos:definition "An announcement of the award or non-award of a Contract by a Buyer."@en ;
    skos:historyNote "WG Approval 27/03/2019"@en ;
    skos:prefLabel "Result Notice"@en .

epo:ReviewInformation a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsReviewDecision ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:relatesToEFormSectionIdentifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsReviewRequest ] ;
    skos:definition "Information about the Review Decision or the Review Request."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Review Information"@en .

epo:concernsProcedure a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( epo:EvidenceSubmission epo:AwardDecisionNotification m8g:InformationRequirement epo:EvidenceRequest epo:ResultNotice epo:ProcurementProcessInformation epo:ContractModificationNotice epo:ExpressionOfInterest epo:ESPDRequest epo:CompletionNotice ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:EvidenceSubmission epo:EvidenceRequest ) ],
        [ a owl:Class ;
            owl:unionOf ( epo:CompletionNotice epo:ContractModificationNotice epo:ResultNotice ) ],
        epo:AwardDecisionNotification,
        epo:ESPDRequest ;
    rdfs:range epo:Procedure ;
    skos:definition "Relates to Procedure."@en ;
    skos:historyNote "WG Approval 05/03/2024"@en ;
    skos:prefLabel "concerns Procedure"@en .

epo:Batch a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:isProductionOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBestBeforeDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasExpiryDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBatchID ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasManufactureDate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasBatchID ] ;
    skos:definition "A production lot in which the Item instances were produced."@en ;
    skos:historyNote "WG Approval 10/03/2022"@en ;
    skos:prefLabel "Batch"@en .

epo:ESPDRequest a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:concernsProcedure ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:specifiesProcurementCriterion ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty epo:specifiesProcurementCriterion ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:concernsProcedure ],
        epo:ProcurementDocument ;
    skos:definition "A document issued by a Buyer defining how the Exclusion Grounds and the Selection Criteria should be addressed in an European Single Procurement Document for a specific procurement."@en ;
    skos:historyNote "WG Approval 05/03/2024"@en ;
    skos:prefLabel "ESPD Request"@en .

epo:ProcurementCriterion a owl:Class ;
    skos:definition "A criterion specific to Procurement."@en ;
    skos:historyNote "WG Approval 23/04/2020"@en ;
    skos:prefLabel "Procurement Criterion"@en .

epo:ProcurementProcessInformation a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isCompetitionTerminated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isDPSTerminated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsLot ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:isToBeRelaunched ],
        epo:ContextDescription ;
    skos:definition "Information about the temporal unfolding or succession of Procurement Objects."@en ;
    skos:prefLabel "Procurement Process Information"@en .

epo:QualificationCriterion a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationCriteriaStatedInProcurementDocuments ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationCriteriaStatedInNotice ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasQualificationCriteriaStatedInESPDRequest ],
        epo:ProcurementCriterion ;
    skos:definition "Criterion used in the first stage of procurement."@en ;
    skos:historyNote "WG approval 30/05/2023"@en ;
    skos:prefLabel "Qualification Criterion"@en .

epo:ReceiptAdviceLine a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOversupplyQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasShortQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRejectedQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasOversupplyQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasRejectedQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasReceivedQuantity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasShortQuantity ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:isSubmittedForDespatchLine ],
        epo:Line ;
    skos:definition "Details concerning the Fulfilment of a Despatch Line."@en ;
    skos:historyNote "WG approval 16/09/2025"@en ;
    skos:prefLabel "Receipt Advice Line"@en .

epo:MaskableObject a owl:Class ;
    skos:definition "Entity within the procurement data model whose visibility, accessibility, or disclosure may be conditionally restricted due to legal, confidentiality, or security requirements."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Maskable Object"@en .

epo:EnvironmentalEmissionInformation a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsTransportMeans ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsItem ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasCalculationMethod ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:concernsTransportMeans ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasMeasure ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:hasMeasure ] ;
    skos:definition "Information about the emissions related to a product, work or service that are released into the environment."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Environmental Emission Information"@en .

epo:Line a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAssociatedDocument ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAdditionalInformation ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty epo:specifiesItem ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty epo:hasAssociatedDocument ] ;
    skos:definition "Component of a document providing specific information."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Line"@en .

epo:ContextDescription a owl:Class ;
    skos:definition "A description concerning a Procurement Object or a Notice in a specific Situation Context. Additional Information: The description has its own identity (+I) but is dependent (+D) on the concerned Entity. We say that ContextDescription *concerns* an Entity."@en ;
    skos:prefLabel "Context Description"@en .

epo:DimensionInformation a owl:Class ;
    skos:definition "Information about the physical or measurable attributes of the instance of the concept described."@en ;
    skos:historyNote "WG approval 11/09/2025"@en ;
    skos:prefLabel "Dimension Information"@en .

epo:AbstractItem a owl:Class ;
    skos:definition "Gathering class for the Items, Item Requests and Deliverables. Additional information: The subclasses have in common that they are related to a procurement need."@en ;
    skos:historyNote "WG approval 09/10/2025"@en ;
    skos:prefLabel "Abstract Item"@en .

epo:Document a owl:Class ;
    skos:definition "A set of interrelated Business Information representing the Business facts and associated metadata. The information may be conveyed in any language, medium or form, including textual, numerical, graphic, cartographic, audio-visual forms, etc."@en ;
    skos:historyNote "WG approval 23/05/2019"@en ;
    skos:prefLabel "Document"@en .

epo:Notice a owl:Class ;
    skos:definition "Document published by the Buyer about market opportunities and results."@en ;
    skos:historyNote "WG Approval 23/05/2019"@en ;
    skos:prefLabel "Notice"@en .

epo:Quantity a owl:Class ;
    skos:definition "A counted number of non-monetary units possibly including fractions."@en ;
    skos:prefLabel "Quantity"@en .

